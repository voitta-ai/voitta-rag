# voitta-rag configuration

# Suppress HuggingFace tokenizers fork warning
TOKENIZERS_PARALLELISM=false

# Root folder for file management (absolute path)
VOITTA_ROOT_PATH=/path/to/voitta-rag-data

# Database path
VOITTA_DB_PATH=./voitta.db

# Server settings
VOITTA_HOST=0.0.0.0
VOITTA_PORT=8000
VOITTA_DEBUG=true

# Qdrant settings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=voitta_documents_v2

# Embedding settings
EMBEDDING_MODEL=intfloat/e5-base-v2
EMBEDDING_DIMENSION=768
EMBEDDING_DEVICE=auto  # auto, cpu, or cuda

# Chunking settings
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=recursive

# Hybrid search: keyword (sparse/BM25) weight (0=dense only, 1=sparse only)
SPARSE_WEIGHT=0.1

# PDF bucketing settings (splitting large PDFs for processing)
PDF_PAGES_PER_BUCKET=20

# Indexing worker settings
INDEXING_POLL_INTERVAL=10

# MCP server settings
MCP_PORT=8001
MCP_TRANSPORT=streamable-http  # streamable-http (default) or sse (for Claude Code)
MCP_SEARCH_LIMIT=20  # Default number of search results

# Base URL for OAuth redirect callbacks
VOITTA_BASE_URL=https://your-domain.com

# Microsoft login (Azure AD / Entra ID)
MS_AUTH_TENANT_ID=
MS_AUTH_CLIENT_ID=
MS_AUTH_CLIENT_SECRET=

# Google login (OAuth2)
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# User seeding (create users from a text file, one username per line)
VOITTA_SEED_USERS=false
VOITTA_USERS_FILE=users.txt

# Docker-specific settings (only used by docker-compose.yml)
DOCKER_PORT=58000  # Host port mapped to container's 8000
MODEL_CACHE_DIR=~/.cache/huggingface  # Host path to HuggingFace model cache
SSH_KEY_DIR=~/.ssh  # Host path to SSH keys (for git sync)
